{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capability manifest",
  "description": "Describes a capability so a generator/skill can copy the right files, deps and env vars into a target app. Two kinds: a `port` is swappable between adapters; a `module` has a single implementation (or none) and is vendored as-is.",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": { "type": "string" },
    "kind": {
      "enum": ["port", "module"],
      "default": "port",
      "description": "`port`: several adapters, swappable at the composition root. `module`: one provider, used directly, because abstracting it would cost more than it buys."
    },
    "description": { "type": "string" },
    "sharedDeps": { "type": "array", "items": { "type": "string" } },
    "peerDeps": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "module" } }, "required": ["kind"] },
      "then": {
        "required": ["files"],
        "properties": {
          "provider": {
            "type": "string",
            "description": "The single provider this module wraps, when there is one (`inngest`, `sentry`). Absent for dependency-free modules."
          },
          "deps": { "type": "array", "items": { "type": "string" } },
          "env": { "type": "array", "items": { "type": "string" } },
          "files": { "type": "array", "items": { "type": "string" } },
          "frameworks": {
            "type": "object",
            "description": "Per-framework extras, when wiring differs by framework (`next`, `tanstack`).",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "deps": { "type": "array", "items": { "type": "string" } },
                "env": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      },
      "else": {
        "required": ["defaultAdapter", "adapters"],
        "properties": {
          "port": { "type": "string", "description": "Path to the port interface file." },
          "factory": { "type": "string", "description": "Path to the composition-root factory." },
          "defaultAdapter": { "type": "string" },
          "adapters": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["deps", "env", "files"],
              "properties": {
                "deps": { "type": "array", "items": { "type": "string" } },
                "env": { "type": "array", "items": { "type": "string" } },
                "files": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "sharedFiles": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  ]
}
