{
  "name": "@alfredmouelle/create-stack",
  "version": "0.4.0",
  "type": "module",
  "description": "Interactive, deterministic installer for the personal reference stack — forks a base app (Next.js / TanStack Start) and strips it to your selection.",
  "author": {
    "name": "Alfred MOUELLE",
    "email": "alfredmouelle@gmail.com",
    "url": "https://alfredmouelle.com"
  },
  "license": "MIT",
  "keywords": [
    "create",
    "scaffold",
    "starter",
    "boilerplate",
    "tanstack-start",
    "nextjs",
    "drizzle",
    "trpc",
    "better-auth"
  ],
  "bin": {
    "create-stack": "./index.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "index.mjs",
    "lib",
    "templates",
    "_stack",
    "README.md",
    "docs/demo.gif"
  ],
  "scripts": {
    "bundle": "node scripts/bundle.mjs",
    "prepack": "node scripts/bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "RUN_SMOKE=1 vitest run test/smoke.test.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
