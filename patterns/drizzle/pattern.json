{
  "$schema": "../../pattern.schema.json",
  "name": "drizzle",
  "description": "Drizzle ORM + drizzle-kit (Postgres / node-postgres). DB client, schema barrel, cursor (keyset) pagination helpers and a seed harness.",
  "framework": "tanstack-start",
  "detect": {
    "deps": ["drizzle-orm"],
    "files": ["drizzle.config.ts"]
  },
  "dependsOn": [],
  "deps": ["drizzle-orm", "pg"],
  "devDeps": ["drizzle-kit", "dotenv", "tsx", "@types/pg", "@faker-js/faker"],
  "env": ["DATABASE_URL"],
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/server/db/seed.ts"
  },
  "files": [
    { "from": "files/drizzle.config.ts", "to": "drizzle.config.ts" },
    { "from": "files/server/db/index.ts", "to": "<srcRoot>/server/db/index.ts" },
    { "from": "files/server/db/keyset.ts", "to": "<srcRoot>/server/db/keyset.ts" },
    { "from": "files/server/db/seed.ts", "to": "<srcRoot>/server/db/seed.ts" },
    { "from": "files/server/db/schemas/index.ts", "to": "<srcRoot>/server/db/schemas/index.ts" }
  ],
  "notes": [
    "drizzle.config.ts globs ./src/server/db/schemas/*.schema.ts — adjust the path if the project's source root is not ./src."
  ]
}
