{
  "name": "@alfredmouelle/stack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Agnostic SaaS foundation: swappable capabilities behind ports & adapters (mailer, storage, jobs, cache, logger, analytics, error-tracking), framework-agnostic, with create-stack & add-capability skills.",
  "author": {
    "name": "Alfred MOUELLE",
    "email": "alfredmouelle@gmail.com",
    "url": "https://alfredmouelle.com"
  },
  "license": "MIT",
  "homepage": "https://create-stack.alfredmouelle.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alfredmouelle/create-stack.git"
  },
  "bugs": {
    "url": "https://github.com/alfredmouelle/create-stack/issues"
  },
  "keywords": [
    "monorepo",
    "ports-and-adapters",
    "hexagonal",
    "agnostic",
    "saas",
    "boilerplate",
    "turbo",
    "pnpm"
  ],
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "create-stack": "node cli/index.mjs",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "link:skills": "./scripts/link-skills.sh --claude",
    "link:skills:codex": "./scripts/link-skills.sh --codex",
    "unlink:skills": "./scripts/link-skills.sh --claude --unlink",
    "unlink:skills:codex": "./scripts/link-skills.sh --codex --unlink"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9",
    "vite": "^8.0.16"
  }
}
