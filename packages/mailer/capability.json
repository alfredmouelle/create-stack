{
  "$schema": "../../capability.schema.json",
  "name": "mailer",
  "description": "Transactional email. Bodies are always React Email components, rendered to HTML + plain text.",
  "port": "src/port.ts",
  "factory": "src/factory.ts",
  "defaultAdapter": "resend",
  "adapters": {
    "resend": {
      "deps": ["resend"],
      "env": ["RESEND_API_KEY"],
      "files": ["src/adapters/resend.ts"]
    },
    "brevo": {
      "deps": ["@getbrevo/brevo"],
      "env": ["BREVO_API_KEY"],
      "files": ["src/adapters/brevo.ts"]
    },
    "ses": {
      "deps": ["@aws-sdk/client-sesv2"],
      "env": ["AWS_REGION", "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"],
      "files": ["src/adapters/ses.ts"]
    }
  },
  "sharedDeps": ["react-email"],
  "peerDeps": ["react", "react-dom"],
  "sharedFiles": ["src/port.ts", "src/address.ts", "src/factory.ts", "src/index.ts"]
}
