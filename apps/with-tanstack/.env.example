# Each capability is selected by a *_PROVIDER var; only the chosen adapter's keys
# are read. Defaults are dev-friendly (local / memory / console / noop).

# mailer — resend | brevo
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=
BREVO_API_KEY=

# storage — s3 | r2 | gcs | local
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=.storage
STORAGE_PUBLIC_URL=http://localhost:3000/files
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
GCS_BUCKET=
GOOGLE_CLOUD_PROJECT=

# jobs — inngest | memory
JOBS_PROVIDER=memory
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# logger — pino | console
LOGGER_PROVIDER=console
LOG_LEVEL=info

# cache — redis | memory
CACHE_PROVIDER=memory
REDIS_URL=

# analytics — posthog | noop
ANALYTICS_PROVIDER=noop
POSTHOG_API_KEY=
POSTHOG_HOST=

# error tracking — sentry | console
ERROR_TRACKING_PROVIDER=console
SENTRY_DSN=
SENTRY_ENVIRONMENT=
